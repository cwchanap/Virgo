# Server endpoints consumed by ServerConfig at runtime.
#
# Local dev:
#   cp Virgo/Config/ServerEndpoints.env.example Virgo/Config/ServerEndpoints.env
#   then edit the values. ServerEndpoints.env is gitignored.
#
# CI:
#   The build generates Virgo/Config/ServerEndpoints.env from GitHub repository
#   variables (see .github/scripts/generate-endpoints-env.sh):
#     - GRAPHQL_ENDPOINT   (vars.GRAPHQL_ENDPOINT)
#     - R2_BASE_URL        (vars.R2_BASE_URL)
#   No real values are committed to this repo.
#
# When ServerEndpoints.env is absent or a key is empty, ServerConfig falls back
# to the local-dev placeholder endpoint and disables audio downloads so the
# build never breaks.
GRAPHQL_ENDPOINT=https://your-graphql-host.example.com/graphql
R2_BASE_URL=https://your-r2-bucket.example.com
