Virgo/Fixtures/soukyuu_e_no_shouka/*.XA
Virgo/Fixtures/soukyuu_e_no_shouka/*.ogg
Virgo/Fixtures/soukyuu_e_no_shouka/*.jpg

# Server DTX files (for testing only)
server/dtx_files/
server/__pycache__/
server/.venv/

# Xcode test results and build artifacts
*.xcresult/
Test-*.xcresult/
DerivedData*/
*.xcuserdata/
TestResults/
build-for-testing*.log
test-output.log
ui-test-*/
ui-test-*.log
ui-test-build-output-*.log
ui-test-results-*/
ui-test-results-diagnostics
ui-test-activity-log.json
.worktrees/

